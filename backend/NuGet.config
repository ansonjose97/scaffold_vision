<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    This project deliberately has zero external NuGet dependencies.
    It builds entirely on the .NET 8 framework references.
    The empty packageSources section disables network restore so the project
    builds offline without needing access to nuget.org.
  -->
  <packageSources>
    <clear />
  </packageSources>
</configuration>
